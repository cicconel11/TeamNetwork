{
  "name": "@teammeet/mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_USE_WATCHMAN=1 expo start",
    "start:dev-client": "EXPO_USE_WATCHMAN=1 expo start --dev-client",
    "dev:mobile": "EXPO_USE_WATCHMAN=1 expo start",
    "android": "EXPO_USE_WATCHMAN=1 ./scripts/with-android-env.sh expo start --android --dev-client",
    "android:doctor": "./scripts/with-android-env.sh sh -c 'printf \"ANDROID_HOME=%s\\nJAVA_HOME=%s\\n\" \"$ANDROID_HOME\" \"$JAVA_HOME\"; java -version; command -v adb; command -v emulator || true'",
    "ios": "EXPO_USE_WATCHMAN=1 expo start --ios --dev-client",
    "web": "EXPO_USE_WATCHMAN=1 expo start --web",
    "prebuild": "EXPO_USE_WATCHMAN=1 expo prebuild",
    "prebuild:clean": "EXPO_USE_WATCHMAN=1 expo prebuild --clean",
    "run:android": "EXPO_USE_WATCHMAN=1 ./scripts/with-android-env.sh expo run:android",
    "run:ios": "EXPO_USE_WATCHMAN=1 expo run:ios",
    "config": "expo config --type public",
    "config:introspect": "expo config --type introspect",
    "eas:ios:list": "eas build:list --platform ios --limit 20",
    "eas:ios:production": "eas build --platform ios --profile production",
    "eas:ios:production:auto-submit": "eas build --platform ios --profile production --auto-submit",
    "eas:submit:ios": "eas submit --platform ios --latest",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default"
  },
  "dependencies": {
    "@bacons/apple-targets": "^0.2.0",
    "@expo-google-fonts/dm-serif-display": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/cli": "^54.0.21",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.9.1",
    "@react-navigation/drawer": "^7.7.13",
    "@react-navigation/elements": "^2.9.5",
    "@react-navigation/native": "^7.1.28",
    "@sentry/react-native": "^7.9.0",
    "@supabase/supabase-js": "^2.39.6",
    "@teammeet/core": "workspace:*",
    "@teammeet/types": "workspace:*",
    "@teammeet/validation": "workspace:*",
    "expo": "^54.0.31",
    "expo-apple-authentication": "^55.0.13",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "^55.0.13",
    "expo-calendar": "^55.0.14",
    "expo-camera": "^55.0.16",
    "expo-clipboard": "^55.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "^14.0.8",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "^55.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^55.0.12",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "^55.0.13",
    "expo-modules-core": "~3.0.29",
    "expo-notifications": "^0.32.16",
    "expo-quick-actions": "^6.0.1",
    "expo-router": "~6.0.21",
    "expo-secure-store": "^55.0.11",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^0.562.0",
    "posthog-react-native": "^4.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.1",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "schema-utils": "^4.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/runtime": "^7.28.6",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.29",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.9",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
