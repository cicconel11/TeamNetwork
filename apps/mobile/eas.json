{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_MOBILE_LIVE_ACTIVITIES_ENABLED": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_MOBILE_LIVE_ACTIVITIES_ENABLED": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6764461380"
      }
    }
  }
}
