# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web API URL (for API calls to the web app)
EXPO_PUBLIC_WEB_URL=https://www.myteamnetwork.com

# Google OAuth (required for native Google Sign-In in a dev build / standalone app)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id

# Analytics - PostHog (product analytics)
EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxx
# Optional — defaults to https://us.i.posthog.com if unset. Set to
# https://eu.i.posthog.com (or self-hosted URL) if your project lives there.
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error Tracking - Sentry
EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# iOS Live Activities (lock-screen / Dynamic Island event widgets).
# Build-time gate. Must be "true" for the LiveActivityProvider to start
# activities — otherwise the whole feature is a no-op.
EXPO_PUBLIC_MOBILE_LIVE_ACTIVITIES_ENABLED=true

# Cloudflare Turnstile (auth + donations)
# Use 1x00000000000000000000AA in dev for an always-pass test key.
EXPO_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# Document origin for the in-WebView captcha widget. Must match a domain
# allow-listed on the Turnstile site key (typically the web app URL).
EXPO_PUBLIC_CAPTCHA_BASE_URL=https://www.myteamnetwork.com

# Stripe — required for the iOS Payment Sheet (Apple Pay) donation flow.
# Use the publishable key from your Stripe Dashboard (test or live). The mobile
# app passes a per-org connected account ID at init time, so this is the
# platform publishable key, NOT a connected-account one.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# App Review (Apple Guideline 2.1) — email of the App Review test account.
# When the signed-in user's email matches this, the iOS donation flow skips the
# Turnstile captcha so the reviewer can reach the Apple Pay Payment Sheet. The
# server only honors that bypass for the matching Supabase user id, listed in
# APP_REVIEW_REVIEWER_USER_IDS (web env). Leave unset outside review builds.
EXPO_PUBLIC_APP_REVIEW_EMAIL=test-reviewer@myteamnetwork.com
