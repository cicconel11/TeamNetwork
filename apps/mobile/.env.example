# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web API URL (for API calls to the web app)
EXPO_PUBLIC_WEB_URL=https://www.myteamnetwork.com

# Google OAuth (required for native Google Sign-In in a dev build / standalone app)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id

# Analytics - PostHog (product analytics)
EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxx
# Optional — defaults to https://us.i.posthog.com if unset. Set to
# https://eu.i.posthog.com (or self-hosted URL) if your project lives there.
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error Tracking - Sentry
EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Cloudflare Turnstile (auth + donations)
# Use 1x00000000000000000000AA in dev for an always-pass test key.
EXPO_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# Document origin for the in-WebView captcha widget. Must match a domain
# allow-listed on the Turnstile site key (typically the web app URL).
EXPO_PUBLIC_CAPTCHA_BASE_URL=https://www.myteamnetwork.com
