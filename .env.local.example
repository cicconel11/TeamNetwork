# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# Core app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# Optional locally, required on Vercel production when using donation webhooks
STRIPE_WEBHOOK_SECRET_CONNECT=your-stripe-connect-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Organization subscription price IDs
STRIPE_PRICE_BASE_MONTHLY=price_xxx
STRIPE_PRICE_BASE_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_0_250_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_0_250_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_251_500_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_251_500_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_501_1000_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_501_1000_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_1001_2500_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_1001_2500_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_2500_5000_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_2500_5000_YEARLY=price_xxx

# Enterprise price IDs
STRIPE_PRICE_ENTERPRISE_ALUMNI_BUCKET_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_ALUMNI_BUCKET_YEARLY=price_xxx
STRIPE_PRICE_ENTERPRISE_SUB_ORG_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_SUB_ORG_YEARLY=price_xxx

# v2 pricing test slice — Stripe Product for dynamic-amount custom-quote checkout.
# Manually create one Product in Stripe dashboard called "TeamNetwork Plan v2"
# and paste its prod_… ID here.
STRIPE_PRODUCT_ID_DYNAMIC=prod_your_v2_test_product

# Cloudflare Turnstile (captcha)
NEXT_PUBLIC_CAPTCHA_PROVIDER=turnstile
CAPTCHA_PROVIDER=turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Legacy hCaptcha fallback (only if CAPTCHA_PROVIDER=hcaptcha)
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
# HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# Email / notifications
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@myteamnetwork.com
ADMIN_EMAIL=admin@myteamnetwork.com
ALERT_EMAIL_TO=alerts@example.com

# Cron (graph sync, etc.)
# Optional locally; required on Vercel production (`next.config` enforces in prod)
CRON_SECRET=your-cron-secret

# Google Calendar integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_TOKEN_ENCRYPTION_KEY=your-google-token-encryption-key

# Microsoft Outlook / Microsoft 365 Calendar integration
# Uses GOOGLE_TOKEN_ENCRYPTION_KEY for token encryption.
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# LinkedIn connected accounts (profile sync)
# Redirect URL is not an env var — use `{NEXT_PUBLIC_SITE_URL}/api/linkedin/callback` in the LinkedIn app settings.
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_TOKEN_ENCRYPTION_KEY=your-linkedin-token-encryption-key

# Blackbaud SKY API / OAuth (optional — omit all four to disable; partial config logs a build warning)
BLACKBAUD_CLIENT_ID=your-blackbaud-application-id
BLACKBAUD_CLIENT_SECRET=your-blackbaud-primary-application-secret
BLACKBAUD_TOKEN_ENCRYPTION_KEY=your-32-byte-hex-encryption-key
BLACKBAUD_SUBSCRIPTION_KEY=your-blackbaud-subscription-key

# Blackbaud sync dev caps (NODE_ENV != production only). Production ignores these.
# BLACKBAUD_DEV_PAGE_SIZE — page size sent to /constituents (default 500, max 500)
# BLACKBAUD_DEV_MAX_PAGES — stop after N pages; sets result.partial=true and skips last_synced_at advance
# BLACKBAUD_DEV_SKIP_EMAILS — "true" skips per-constituent email subresource fetch (rate-limit probing only)
# BLACKBAUD_DEV_PAGE_SIZE=5
# BLACKBAUD_DEV_MAX_PAGES=1
# BLACKBAUD_DEV_SKIP_EMAILS=false

# COPPA age-gate API (`/api/auth/validate-age`)
AGE_VALIDATION_SECRET=your-random-secret
# Optional; default salt exists in code — set in production for consistent IP hashing
IP_HASH_SALT=your-random-salt

# Dev-only platform admin (comma-separated emails; see `src/lib/auth/dev-admin.ts`)
# DEV_ADMIN_EMAILS=you@example.com,coworker@example.com

# LinkedIn profile enrichment (~$0.01/lookup when set)
# PROXYCURL_API_KEY=your-proxycurl-key

# AI Assistant (z.ai)
ZAI_API_KEY=your-zai-api-key
# Optional: override default model (e.g. glm-5, glm-4.6v)
ZAI_MODEL=glm-5

# Semantic / embedding features (e.g. AI assistant paths that use embeddings)
# EMBEDDING_API_KEY=your-gemini-api-key

# FalkorDB people graph (`suggest_connections`, graph sync cron)
# Leave unset or FALKOR_ENABLED unset/false to use SQL fallback only.
# FALKOR_URL=redis://user:pass@host:6379
# Or discrete remote:
# FALKOR_ENABLED=true
# FALKOR_HOST=localhost
# FALKOR_PORT=6379
# FALKOR_USERNAME=
# FALKOR_PASSWORD=
# Local embedded (falkordblite + redis-server path auto-detected on macOS):
# FALKOR_ENABLED=true
# FALKOR_EMBEDDED=true


# Development toggles
# SKIP_STRIPE_VALIDATION=true
# NEXT_PUBLIC_DEBUG=true
# LOG_AUTH_VERBOSE=true
# LOG_AUTH_FAILURES=true
