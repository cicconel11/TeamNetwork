{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "ANALYZE",
    "NODE_OPTIONS",
    "SKIP_STRIPE_VALIDATION",
    "VERCEL",
    "VERCEL_ENV",
    "NODE_ENV",
    "CRON_SECRET",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "STRIPE_*",
    "NEXT_PUBLIC_STRIPE_*",
    "EXPO_PUBLIC_STRIPE_*",
    "RESEND_API_KEY",
    "RESEND_DOMAINS_API_KEY",
    "FROM_EMAIL",
    "ALERT_EMAIL_TO",
    "ADMIN_EMAIL",
    "DEV_ADMIN_EMAILS",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_TOKEN_ENCRYPTION_KEY",
    "LINKEDIN_CLIENT_ID",
    "LINKEDIN_CLIENT_SECRET",
    "LINKEDIN_TOKEN_ENCRYPTION_KEY",
    "BLACKBAUD_CLIENT_ID",
    "BLACKBAUD_CLIENT_SECRET",
    "BLACKBAUD_TOKEN_ENCRYPTION_KEY",
    "BLACKBAUD_SUBSCRIPTION_KEY",
    "MICROSOFT_CLIENT_ID",
    "MICROSOFT_CLIENT_SECRET",
    "APNS_KEY_ID",
    "APNS_TEAM_ID",
    "APNS_AUTH_KEY",
    "APPLE_PASS_TYPE_ID_MEMBER",
    "APPLE_PASS_TEAM_ID",
    "APPLE_PASS_SIGNER_CERT_PEM",
    "APPLE_PASS_SIGNER_KEY_PEM",
    "APPLE_PASS_SIGNER_KEY_PASSPHRASE",
    "APPLE_WWDR_CERT_PEM",
    "EXPO_ACCESS_TOKEN",
    "AUTH_HANDOFF_ENCRYPTION_KEY",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "TURNSTILE_SECRET_KEY",
    "IP_HASH_SALT",
    "AGE_VALIDATION_SECRET",
    "APIFY_API_TOKEN",
    "APIFY_LINKEDIN_ACTOR_ID",
    "APIFY_WEBHOOK_SECRET",
    "ZAI_API_KEY",
    "ZAI_MODEL",
    "ZAI_MODEL_FALLBACK",
    "ZAI_MODEL_PASS1",
    "ZAI_IMAGE_MODEL",
    "ZAI_TIMEOUT_MS",
    "ZAI_MAX_RETRIES",
    "AI_PASS1_TEMPERATURE",
    "AI_PASS2_TEMPERATURE",
    "AI_PASS1_MAX_TOKENS",
    "AI_PASS2_MAX_TOKENS",
    "SAFETY_JUDGE_MODEL",
    "SAFETY_JUDGE_FAIL_MODE",
    "SAFETY_JUDGE_FAIL_OPEN",
    "SAFETY_MIN_CHARS_FOR_LLM",
    "RAG_GROUNDING_JUDGE_MODEL",
    "RAG_GROUNDING_JACCARD_THRESHOLD",
    "EMBEDDING_API_KEY",
    "EMBEDDING_MODEL",
    "EMBEDDING_BASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^typecheck"]
    },
    "test:auth": {},
    "test:payments": {},
    "test:security": {}
  }
}
