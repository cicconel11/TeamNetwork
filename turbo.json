{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "ANALYZE",
    "SKIP_STRIPE_VALIDATION",
    "VERCEL",
    "VERCEL_ENV",
    "NODE_ENV",
    "CRON_SECRET",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "STRIPE_*",
    "NEXT_PUBLIC_STRIPE_*",
    "RESEND_API_KEY",
    "FROM_EMAIL",
    "ALERT_EMAIL_TO",
    "ADMIN_EMAIL",
    "DEV_ADMIN_EMAILS",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_TOKEN_ENCRYPTION_KEY",
    "LINKEDIN_CLIENT_ID",
    "LINKEDIN_CLIENT_SECRET",
    "LINKEDIN_TOKEN_ENCRYPTION_KEY",
    "BLACKBAUD_CLIENT_ID",
    "BLACKBAUD_CLIENT_SECRET",
    "BLACKBAUD_TOKEN_ENCRYPTION_KEY",
    "BLACKBAUD_SUBSCRIPTION_KEY",
    "MICROSOFT_CLIENT_ID",
    "MICROSOFT_CLIENT_SECRET",
    "APNS_KEY_ID",
    "APNS_TEAM_ID",
    "APNS_AUTH_KEY",
    "EXPO_ACCESS_TOKEN",
    "AUTH_HANDOFF_ENCRYPTION_KEY",
    "CAPTCHA_PROVIDER",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "TURNSTILE_SECRET_KEY",
    "IP_HASH_SALT",
    "AGE_VALIDATION_SECRET",
    "BRIGHT_DATA_API_KEY",
    "ZAI_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^typecheck"]
    },
    "test:auth": {},
    "test:payments": {},
    "test:security": {}
  }
}
